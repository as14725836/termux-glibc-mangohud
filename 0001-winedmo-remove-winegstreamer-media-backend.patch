+static void flip_bottom_up_rgb_rows(BYTE *data, DWORD size, const DMO_MEDIA_TYPE *type)
+{
+    const VIDEOINFOHEADER *info;
+    LONG width, height, stride;
+    BYTE *tmp;
+
+    if (!type->pbFormat || type->cbFormat < sizeof(*info) || !is_dmo_rgb_subtype(&type->subtype))
+        return;
+
+    info = (const VIDEOINFOHEADER *)type->pbFormat;
+    if (info->bmiHeader.biHeight <= 0)
+        return;
+
+    width = info->bmiHeader.biWidth;
+    height = info->bmiHeader.biHeight;
+    stride = ((width * info->bmiHeader.biBitCount + 31) / 32) * 4;
+    if (!width || height <= 1 || !stride || size < stride * height)
+        return;
+
+    if (!(tmp = malloc(stride)))
+        return;
+
+    for (LONG y = 0; y < height / 2; ++y)
+    {
+        BYTE *top = data + y * stride;
+        BYTE *bottom = data + (height - y - 1) * stride;
+
+        memcpy(tmp, top, stride);
+        memcpy(top, bottom, stride);
+        memcpy(bottom, tmp, stride);
+    }
+
+    free(tmp);
+}
