-
-    GST_DEBUG("caps %"GST_PTR_FORMAT", out %p.", caps, out);
-
-    if (!gst_structure_get_int(structure, "wmaversion", &wmaversion))
-    {
-        GST_ERROR("Caps have no wmaversion field.");
