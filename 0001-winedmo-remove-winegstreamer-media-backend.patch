-            return true;
-        break;
-    case GST_QUERY_CAPS:
-        if (transform_sink_query_caps(transform, query))
-            return true;
-        break;
-    default:
-        break;
-    }
-
-    GST_TRACE("transform %p, ignoring %"GST_PTR_FORMAT, transform, query);
-    return gst_pad_query_default(pad, parent, query);
