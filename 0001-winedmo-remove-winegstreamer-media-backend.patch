-    RB_FOR_EACH_ENTRY(chunk, &chunks_to_discard, struct fozdb_entry, entry)
-    {
-        if (!rb_get(&chunks_to_keep, chunk))
-            fozdb_entry_put(&chunks, chunk->key.tag, &chunk->key.hash);
-    }
