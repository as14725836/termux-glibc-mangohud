+        return false;
+    }
+
+    format->major_type = WINEDMO_MAJOR_TYPE_AUDIO_MPEG1;
+    format->u.audio.channels = audio_format->wfx.nChannels;
+    format->u.audio.rate = audio_format->wfx.nSamplesPerSec;
+    format->u.audio.layer = audio_format->fwHeadLayer;
