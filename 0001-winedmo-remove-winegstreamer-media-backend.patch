-static int stream_state_serializer_read(void *data_reader, uint8_t *buffer, size_t size, size_t *read_size)
-{
-    struct stream_state_serializer *serializer = data_reader;
-    struct buffer_entry *entry;
-
-    if (!size)
-    {
-        *read_size = 0;
