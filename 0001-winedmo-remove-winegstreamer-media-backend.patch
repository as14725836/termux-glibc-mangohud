+static void fill_32bit_alpha(BYTE *data, DWORD size, const DMO_MEDIA_TYPE *type)
+{
+    const VIDEOINFOHEADER *info;
+
+    if (!type->pbFormat || type->cbFormat < sizeof(*info)
+            || (!IsEqualGUID(&type->subtype, &MEDIASUBTYPE_RGB32)
+                    && !IsEqualGUID(&type->subtype, &MEDIASUBTYPE_ARGB32)))
+        return;
+
+    info = (const VIDEOINFOHEADER *)type->pbFormat;
+    if (info->bmiHeader.biBitCount != 32 || info->bmiHeader.biCompression != BI_RGB)
+        return;
+
+    /* Texture renderers commonly treat the high RGB32 byte as alpha. */
+    for (DWORD i = 3; i < size; i += 4)
+        data[i] = 0xff;
+}
