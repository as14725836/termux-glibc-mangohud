-                structure = gst_caps_get_structure(filter, i);
-                gst_caps_append_structure(result, gst_structure_copy(structure));
-            }
-        }
-
-        GST_INFO("Result %"GST_PTR_FORMAT, result);
-        gst_query_set_caps_result(query, result);
-
-        return TRUE;
-    }
-
-    return FALSE;
