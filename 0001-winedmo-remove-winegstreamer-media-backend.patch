+static BOOL is_wma_decoder_input_subtype(const GUID *subtype)
+{
+    unsigned int i;
+
+    for (i = 0; i < ARRAY_SIZE(wma_decoder_input_types); ++i)
+    {
+        if (IsEqualGUID(subtype, wma_decoder_input_types[i]))
+            return TRUE;
+    }
+
