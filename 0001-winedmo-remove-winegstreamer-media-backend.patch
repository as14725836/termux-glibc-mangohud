+static BOOL is_mpeg4_part2_decoder(struct video_decoder *decoder)
+{
+    GUID subtype;
+
+    if (!decoder->input_type || FAILED(IMFMediaType_GetGUID(decoder->input_type, &MF_MT_SUBTYPE, &subtype)))
+        return FALSE;
+
+    switch (subtype.Data1)
+    {
+        case MAKEFOURCC('M','4','S','2'):
+        case MAKEFOURCC('M','P','4','S'):
+        case MAKEFOURCC('M','P','4','V'):
+        case MAKEFOURCC('m','p','4','v'):
+        case MAKEFOURCC('D','I','V','X'):
+        case MAKEFOURCC('D','X','5','0'):
+        case MAKEFOURCC('F','M','P','4'):
+        case MAKEFOURCC('X','V','I','D'):
+            return TRUE;
+    }
+
+    return FALSE;
+}
