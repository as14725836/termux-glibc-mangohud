-        GST_ERROR("%"GST_PTR_FORMAT" failed to activate.", pool);
-
-    gst_query_add_allocation_pool(query, GST_BUFFER_POOL(pool), pool->info.size, 0, 0);
-    gst_query_add_allocation_param(query, transform->allocator, NULL);
