+static HRESULT create_decoder_output_sample(struct video_decoder *decoder, const GUID *subtype, UINT64 frame_size,
+        UINT32 sample_size, IMFSample **out)
+{
+    UINT32 height = (UINT32)frame_size, stride, width = frame_size >> 32;
+    BOOL use_compact_buffer = IsEqualGUID(subtype, &MFVideoFormat_NV12) && (width % 16 || height % 16);
+    IMFMediaBuffer *buffer = NULL;
+    DWORD size;
+    HRESULT hr;
+
+    if (decoder->temp_buffer)
+    {
+        if (FAILED(IMFMediaBuffer_GetMaxLength(decoder->temp_buffer, &size)) || size < sample_size)
+        {
+            IMFMediaBuffer_Release(decoder->temp_buffer);
+            decoder->temp_buffer = NULL;
+        }
+    }
+    if (!decoder->temp_buffer)
+    {
+        if (use_compact_buffer)
+            hr = MFCreateMemoryBuffer(sample_size, &decoder->temp_buffer);
+        else
+            hr = MFCreate2DMediaBuffer(width, height, subtype->Data1,
+                    SUCCEEDED(IMFMediaType_GetUINT32(decoder->output_type, &MF_MT_DEFAULT_STRIDE, &stride))
+                    && (INT32)stride < 0, &decoder->temp_buffer);
+        if (FAILED(hr) && FAILED(hr = MFCreateMemoryBuffer(sample_size, &decoder->temp_buffer)))
+            return hr;
+    }
+
+    if (FAILED(hr = MFCreateSample(out)))
+        return hr;
+    if (FAILED(hr = IMFSample_AddBuffer(*out, decoder->temp_buffer)))
+    {
+        IMFSample_Release(*out);
+        *out = NULL;
+        return hr;
+    }
+
+    if (SUCCEEDED(IMFSample_ConvertToContiguousBuffer(*out, &buffer)))
+    {
+        IMFMediaBuffer_SetCurrentLength(buffer, 0);
+        IMFMediaBuffer_Release(buffer);
+    }
+
+    return S_OK;
+}
