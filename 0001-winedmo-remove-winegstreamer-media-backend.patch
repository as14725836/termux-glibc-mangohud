-                else
-                    GST_WARNING("Autoplugged element failed to initialise, trying again with protonvideoconvert.");
-            }
-            pthread_mutex_unlock(&parser->mutex);
-        }
-        break;
-
-    case GST_MESSAGE_STREAM_STATUS:
-    {
-        GstStreamStatusType type;
-        GstElement *element;
-        const GValue *val;
-        GstTask *task;
