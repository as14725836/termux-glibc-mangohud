-    wg_sample->size = 0;
-
-    if (FAILED(hr = wg_transform_read_data(transform, wg_sample)))
-    {
-        wg_sample_release(wg_sample);
-        return hr;
-    }
-
-    if (wg_sample->flags & WG_SAMPLE_FLAG_INCOMPLETE)
-        *flags |= MFT_OUTPUT_DATA_BUFFER_INCOMPLETE;
