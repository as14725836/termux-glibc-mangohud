+                || IsEqualGUID(subtype, &wma_audio_subtype_wmaudio3)
+                || IsEqualGUID(subtype, &wma_audio_subtype_wmaudio_lossless))
+            return TRUE;
+    }
+
+    return FALSE;
+}
