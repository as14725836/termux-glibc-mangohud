From 2c6f018382154afbba8f60b7fe075b1d2f817fda Mon Sep 17 00:00:00 2001
From: Jade Macho <ade@0x0a.de>
Date: Wed, 18 Mar 2026 02:06:16 +0100
Subject: [PATCH] server: Dynamically relocate .exes by default too

Skip relocation during early process init to avoid breaking
wine's own loader. User .exes are relocated after kernel32 is up.

TODO: Should this only be enabled for Vista onwards? Toggleable?
---
 dlls/ntdll/unix/virtual.c | 17 ++++++++++++++++-
 server/mapping.c          |  2 --
 2 files changed, 16 insertions(+), 3 deletions(-)

diff --git a/dlls/ntdll/unix/virtual.c b/dlls/ntdll/unix/virtual.c
index 781598fced1..a3b7e9d8212 100644
--- a/dlls/ntdll/unix/virtual.c
+++ b/dlls/ntdll/unix/virtual.c
@@ -3407,10 +3407,25 @@ static NTSTATUS virtual_map_image( HANDLE mapping, void **addr_ptr, SIZE_T *size
         *size_ptr = view_size;
     }
 
+    /*
+     * For non-DLL images (exes), only relocate after ntdll init is complete.
+     * During early startup the LDR list contains only ntdll.dll and the main exe;
+     * relocating wine's own loader at that stage breaks page permissions.
+     */
+    {
+        BOOL is_dll = (image_info->image_charact & IMAGE_FILE_DLL) != 0;
+        BOOL early_init = FALSE;
+        if (!is_dll && NtCurrentTeb()->Peb->Ldr)
+        {
+            PLIST_ENTRY head = &NtCurrentTeb()->Peb->Ldr->InLoadOrderModuleList;
+            PLIST_ENTRY e = head->Flink;
+            int count = 0;
+            while (e && e != head && count < 4) { count++; e = e->Flink; }
+            early_init = (count <= 2);  /* only ntdll + self → wine's own loader */
+        }
+
     if (!image_info->map_addr &&
-        (image_info->image_charact & IMAGE_FILE_DLL) &&
+        (!early_init) &&
         (image_info->image_flags & IMAGE_FLAGS_ImageDynamicallyRelocated))
     {
         SERVER_START_REQ( get_image_map_address )
diff --git a/server/mapping.c b/server/mapping.c
index 69cd0a7451b..5e742342514 100644
--- a/server/mapping.c
+++ b/server/mapping.c
@@ -1286,8 +1286,6 @@ static client_ptr_t assign_map_address( struct mapping *mapping )
     struct addr_range *range = (mapping->image.base >> 32) ? &ranges64 : &ranges32;
     mem_size_t size = round_size( mapping->size, granularity_mask );
 
-    if (!(mapping->image.image_charact & IMAGE_FILE_DLL)) return 0;
-
     if ((ret = get_fd_map_address( mapping->fd ))) return ret;
 
     size += granularity_mask + 1;  /* leave some free space between mappings */
-- 
