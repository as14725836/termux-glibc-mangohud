+        }
     }
 
-    if (stream->held_bytes)
+    if (stream->held_bytes && pulse_stream_ready(stream))
         wait_pa_operation_complete(pa_stream_flush(stream->stream, pulse_op_cb, &success));
 
     stream->clock_lastpos = stream->clock_written = 0;
